{
  "buildCommand": "pnpm build:vercel",
  "installCommand": "pnpm install",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/manus-storage/(.*)", "destination": "/api/index.ts" },
    { "source": "/((?!.*\\.)).*", "destination": "/index.html" }
  ]
}
